<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- 开屏页主题（core-splashscreen）。glintapi 深夜底，过渡到 Theme.MyApplication。
         系统阶段只纯色背景（icon 设透明，避免冷启动先闪一个放大的 launcher 图标再进 Compose splash）；
         mesh 渐变 + sparkle logo + 闪烁光标全部在 Activity 内 Compose 品牌 splash 实现，视觉单一连贯。 -->
    <style name="Theme.MyApplication.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>
</resources>
